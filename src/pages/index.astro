---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

// The prose page is the SEO / screen-reader source of truth (HANDOFF §4.3).
// It renders the SAME server-rendered markdown the band's hero box uses (R7).
// The band itself is mounted once in Base.astro — not here.
const sections = (await getCollection('sections')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Wunschnachbarn Bonn eG – Gemeinschaft am Klufterbach">
  <main id="main">
    <article class="scroll-sections">
      {sections.map((section) => (
        <section id={section.id} class="section-prose">
          <header class="section-header">
            <span class="eyebrow">{section.data.label}</span>
            <h2 set:html={section.data.title}></h2>
          </header>
          <div class="section-body" set:html={section.rendered?.html ?? ''}></div>
        </section>
      ))}
    </article>
  </main>

  <Footer />
</Base>

<style>
  main {
    min-height: 100vh;
  }

  .scroll-sections {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--sp-10) var(--sp-5);
  }

  .section-prose {
    scroll-margin-top: 140px; /* Space for sticky nav */
    margin-bottom: var(--sp-10);
    padding-bottom: var(--sp-8);
    border-bottom: 1px solid var(--wn-fog);
  }

  .section-prose:last-of-type {
    border-bottom: none;
  }

  .section-header {
    margin-bottom: var(--sp-6);
  }

  .section-header .eyebrow {
    display: block;
    color: var(--wn-violet);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    margin-bottom: var(--sp-2);
  }

  .section-header h2 {
    font-size: var(--fs-h2);
    margin: 0;
  }

  .section-body {
    font-size: var(--fs-body-lg);
    line-height: var(--lh-loose);
    color: var(--fg-muted);
  }

  .section-body p {
    margin-bottom: 1.5em;
  }

  .section-body h3 {
    font-size: var(--fs-h4);
    font-weight: 700;
    margin-top: var(--sp-6);
    margin-bottom: var(--sp-3);
    color: var(--wn-green-deep);
  }

  .section-body strong {
    color: var(--wn-green-deep);
    font-weight: 700;
  }

  .section-body .cta {
    display: inline-flex;
    align-items: center;
    padding: var(--sp-3) var(--sp-5);
    background: var(--wn-violet);
    color: var(--wn-paper);
    text-decoration: none;
    border-radius: var(--r-pill);
    font-weight: 600;
    transition: background var(--dur-2) var(--ease-out),
                transform var(--dur-1) var(--ease-out);
  }

  .section-body .cta:hover {
    background: #931558;
  }

  .section-body .cta:active {
    transform: scale(0.97);
  }

  /* Active section highlight (for scrollspy) */
  .section-prose.scrollspy-active {
    position: relative;
  }

  .section-prose.scrollspy-active::before {
    content: "";
    position: absolute;
    left: -20px;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--wn-orange);
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .scroll-sections {
      padding: var(--sp-8) var(--sp-4);
    }

    .section-prose {
      scroll-margin-top: 120px;
      margin-bottom: var(--sp-8);
      padding-bottom: var(--sp-6);
    }

    .section-body {
      font-size: var(--fs-body);
    }

    .section-prose.scrollspy-active::before {
      left: -12px;
      width: 3px;
    }
  }
</style>
