---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import KlufterbachNav from '../components/KlufterbachNav.svelte';
import { getCollection, getEntry } from 'astro:content';
import { render } from 'astro:content';

// Get sections from CMS, sorted by order
const sections = await getCollection('sections');
sections.sort((a, b) => a.data.order - b.data.order);

// Get site meta for contact email
const siteMetaEntry = await getEntry('site', 'meta');
const contactEmail = siteMetaEntry?.data.email || 'mitmachen@wunschnachbarn.org';

// Render sections in the frontmatter for access in template
const renderedSections = await Promise.all(
  sections.map(async (section) => ({
    section,
    Content: (await render(section)).Content,
  }))
);
---

<Base title="Wunschnachbarn Bonn eG – Gemeinschaft am Klufterbach">
  <KlufterbachNav client:load transition:persist="klufterbach-nav" />

  <main id="main">
    <article class="scroll-sections">
      {renderedSections.map(({ section, Content }) => (
        <section id={section.id} class="section-prose">
          <header class="section-header">
            <span class="eyebrow">{section.data.label}</span>
            <h2 set:html={section.data.title}></h2>
          </header>
          <div class="section-body">
            {section.id === 'kontakt' ? (
              <>
                <p>Bewende dich gerne per Mail an uns. Wir freuen uns über Dein Interesse.</p>
                <p style="font-family: var(--ff-mono); font-size: 14px; opacity: 0.8; word-break: break-all;">
                  {contactEmail}
                </p>
                <a class="cta" href={`mailto:${contactEmail}`}>Per Mail schreiben →</a>
              </>
            ) : (
              <Content client:load />
            )}
          </div>
        </section>
      ))}
    </article>
  </main>

  <Footer />
</Base>

<style>
  main {
    min-height: 100vh;
  }

  .scroll-sections {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--sp-10) var(--sp-5);
  }

  .section-prose {
    scroll-margin-top: 140px; /* Space for sticky nav */
    margin-bottom: var(--sp-10);
    padding-bottom: var(--sp-8);
    border-bottom: 1px solid var(--wn-fog);
  }

  .section-prose:last-of-type {
    border-bottom: none;
  }

  .section-header {
    margin-bottom: var(--sp-6);
  }

  .section-header .eyebrow {
    display: block;
    color: var(--wn-violet);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    margin-bottom: var(--sp-2);
  }

  .section-header h2 {
    font-size: var(--fs-h2);
    margin: 0;
  }

  .section-body {
    font-size: var(--fs-body-lg);
    line-height: var(--lh-loose);
    color: var(--fg-muted);
  }

  .section-body p {
    margin-bottom: 1.5em;
  }

  .section-body h3 {
    font-size: var(--fs-h4);
    font-weight: 700;
    margin-top: var(--sp-6);
    margin-bottom: var(--sp-3);
    color: var(--wn-green-deep);
  }

  .section-body strong {
    color: var(--wn-green-deep);
    font-weight: 700;
  }

  .section-body .cta {
    display: inline-flex;
    align-items: center;
    padding: var(--sp-3) var(--sp-5);
    background: var(--wn-violet);
    color: var(--wn-paper);
    text-decoration: none;
    border-radius: var(--r-pill);
    font-weight: 600;
    transition: background var(--dur-2) var(--ease-out),
                transform var(--dur-1) var(--ease-out);
  }

  .section-body .cta:hover {
    background: #931558;
  }

  .section-body .cta:active {
    transform: scale(0.97);
  }

  /* Active section highlight (for scrollspy) */
  .section-prose.scrollspy-active {
    position: relative;
  }

  .section-prose.scrollspy-active::before {
    content: "";
    position: absolute;
    left: -20px;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--wn-orange);
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .scroll-sections {
      padding: var(--sp-8) var(--sp-4);
    }

    .section-prose {
      scroll-margin-top: 120px;
      margin-bottom: var(--sp-8);
      padding-bottom: var(--sp-6);
    }

    .section-body {
      font-size: var(--fs-body);
    }

    .section-prose.scrollspy-active::before {
      left: -12px;
      width: 3px;
    }
  }
</style>
