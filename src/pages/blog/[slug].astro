---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import KlufterbachNav from '../../components/KlufterbachNav.svelte';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', p => !p.data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} – Wunschnachbarn Bonn eG`}>
  <KlufterbachNav client:load transition:persist="klufterbach-nav" />

  <main id="main">
    <article class="blog-post-page">
      <header class="post-header">
        <a href="/blog" class="back-link">← Zurück zur Übersicht</a>

        <div class="post-meta">
          <time class="post-date">{post.data.date.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
          <span class="post-category">{post.data.category}</span>
        </div>

        <h1>{post.data.title}</h1>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="back-to-blog-button">
          Alle Beiträge ansehen
        </a>
      </footer>
    </article>
  </main>

  <Footer />
</Base>

<style>
  .blog-post-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-5);
  }

  .post-header {
    margin-bottom: var(--sp-8);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--wn-graphite);
    text-decoration: none;
    border-radius: var(--r-sm);
    margin-bottom: var(--sp-5);
    transition: all var(--dur-2) var(--ease-out);
  }

  .back-link:hover {
    color: var(--wn-violet);
    background: var(--wn-mint-100);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .post-date {
    font-size: var(--fs-body);
    color: var(--wn-graphite);
  }

  .post-category {
    padding: var(--sp-2) var(--sp-4);
    background: var(--wn-mint-100);
    border-radius: var(--r-pill);
    font-size: 14px;
    font-weight: 600;
    color: var(--wn-violet);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-header h1 {
    font-size: var(--fs-h1);
    margin: 0 0 var(--sp-4);
  }

  .post-content {
    font-size: var(--fs-body-lg);
    line-height: var(--lh-loose);
    color: var(--fg);
  }

  .post-content h3 {
    font-size: var(--fs-h4);
    margin: var(--sp-6) 0 var(--sp-3);
  }

  .post-content p {
    margin-bottom: 1.5em;
  }

  .post-content strong {
    color: var(--wn-green-deep);
    font-weight: 700;
  }

  .post-footer {
    margin-top: var(--sp-10);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--wn-fog);
    text-align: center;
  }

  .back-to-blog-button {
    display: inline-flex;
    align-items: center;
    padding: var(--sp-3) var(--sp-5);
    background: var(--wn-violet);
    color: var(--wn-paper);
    text-decoration: none;
    border-radius: var(--r-pill);
    font-weight: 600;
    transition: background var(--dur-2) var(--ease-out),
                transform var(--dur-1) var(--ease-out);
  }

  .back-to-blog-button:hover {
    background: #931558;
  }

  .back-to-blog-button:active {
    transform: scale(0.97);
  }

  @media (max-width: 768px) {
    .blog-post-page {
      padding: var(--sp-6) var(--sp-4);
    }

    .post-header h1 {
      font-size: var(--fs-h2);
    }

    .post-content {
      font-size: var(--fs-body);
    }
  }
</style>
