---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import KlufterbachNav from '../../components/KlufterbachNav.svelte';
import BlogList from '../../components/BlogList.svelte';
import { getCollection } from 'astro:content';

// Get blog posts from CMS
const posts = await getCollection('posts', p => !p.data.draft);

// Map posts to the format expected by BlogList
const blogListPosts = posts.map((post, index) => ({
  id: index + 1, // Use numeric ID for BlogList compatibility
  slug: post.id,
  date: post.data.date.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }),
  category: post.data.category,
  title: post.data.title,
  excerpt: post.data.excerpt,
  heroImage: null, // Empty for v1
}));

// Sort by date (newest first)
blogListPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const categories = ['Alle', 'Plenum', 'Bauphase', 'Werkstatt', 'Garten', 'Soziokratie'];
---

<Base title="Blog – Wunschnachbarn Bonn eG">
  <KlufterbachNav client:load transition:persist="klufterbach-nav" />

  <main id="main">
    <article class="blog-page">
      <header class="blog-header">
        <span class="eyebrow">Blog</span>
        <h1>Aus dem Plenum</h1>
        <p class="blog-subline">
          Berichte aus unseren Arbeitskreisen, Plenen und vom Weg zu unserem gemeinsamen Zuhause.
        </p>
      </header>

      <BlogList
        posts={blogListPosts}
        categories={categories}
        client:load
      />
    </article>
  </main>

  <Footer />
</Base>

<style>
  .blog-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-5);
  }

  .blog-header {
    margin-bottom: var(--sp-8);
    text-align: center;
  }

  .blog-header .eyebrow {
    color: var(--wn-violet);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
  }

  .blog-header h1 {
    font-size: var(--fs-display);
    margin: var(--sp-3) 0 var(--sp-4);
  }

  .blog-subline {
    font-size: var(--fs-body-lg);
    color: var(--fg-muted);
    max-width: 50ch;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .blog-page {
      padding: var(--sp-6) var(--sp-4);
    }

    .blog-header h1 {
      font-size: var(--fs-h2);
    }

    .blog-subline {
      font-size: var(--fs-body);
    }
  }
</style>
