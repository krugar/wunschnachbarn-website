---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import BlogList from '../../components/BlogList.svelte';
import { getCollection } from 'astro:content';

// Import all upload images using an absolute glob pattern
// Note: The pattern must be relative to the project root for Vite's import.meta.glob
const uploadImages = import.meta.glob<{ default: { src: string } }>(
  '/src/assets/uploads/*.{jpg,jpeg,png,gif,webp}',
  { eager: true }
);

// Get blog posts from CMS
const posts = await getCollection('posts', p => !p.data.draft);

// Process images using the pre-imported image map
const blogListPosts = posts.map((post, index) => {
  let heroImage = null;
  let heroAlt = post.data.heroAlt;

  if (post.data.heroImage) {
    try {
      // CMS stores paths like "src/assets/uploads/file.jpg"
      // The globs use keys like "/src/assets/uploads/file.jpg" (with leading slash)
      const globKey = `/${post.data.heroImage}`;

      const imageData = uploadImages[globKey];
      if (imageData) {
        heroImage = {
          src: imageData.default.src,
        };
      }
    } catch (error) {
      console.warn(`Failed to load image for post "${post.data.title}":`, post.data.heroImage, error);
      heroImage = null;
    }
  }

  return {
    id: index + 1,
    slug: post.id,
    date: post.data.date.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }),
    category: post.data.category,
    title: post.data.title,
    excerpt: post.data.excerpt,
    heroImage,
    heroAlt,
  };
});

// Sort by date (newest first)
blogListPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Extract unique categories from posts
const categorySet = new Set(posts.map(p => p.data.category));
const categories = ['Alle', ...Array.from(categorySet).sort()];
---

<Base title="Blog – Wunschnachbarn Bonn eG">
  <main id="main">
    <article class="blog-page">
      <header class="blog-header">
        <span class="eyebrow">Blog</span>
        <h1>Aus dem Plenum</h1>
        <p class="blog-subline">
          Berichte aus unseren Arbeitskreisen, Plenen und vom Weg zu unserem gemeinsamen Zuhause.
        </p>
      </header>

      <BlogList
        posts={blogListPosts}
        categories={categories}
        client:load
      />
    </article>
  </main>

  <Footer />
</Base>
