---
import { ClientRouter } from 'astro:transitions';
import '../styles/colors_and_type.css';
import KlufterbachNav, { type SectionData } from '../components/KlufterbachNav.svelte';
import { getCollection } from 'astro:content';
// Band texture resolved at build time (O3); CSS background, not <img>.
import bandTexture from '../assets/uploads/forest.webp';
import type { StationId } from '../lib/band-state';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Wunschnachbarn Bonn eG – Gemeinschaft am Klufterbach',
  description = 'Wohngenossenschaft in Bonn. Wir bauen gemeinsam nachhaltigen, bezahlbaren Wohnraum.'
} = Astro.props;

// Shape the section content the persisted band needs on '/' (O2). bodyHtml is
// the same server-rendered markdown the prose uses — single source (R7). Today
// one body → one item; the items[] shape is ready for the deferred CMS schema (R14).
const sections = (await getCollection('sections')).sort((a, b) => a.data.order - b.data.order);
const sectionData: SectionData[] = sections.map((s) => ({
  id: s.id as StationId,
  label: s.data.label,
  title: s.data.title,
  items: [
    {
      bodyHtml: s.rendered?.html ?? '',
      image: s.data.image || undefined,
      imageAlt: s.data.imageAlt || undefined,
    },
  ],
}));
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    {/*
      Enable client-side routing with view transitions.
      This gives SPA-style navigation without losing static HTML.
    */}
    <ClientRouter />
  </head>

  <body>
    <!-- Persisted across routes (HANDOFF §7): mounted ONCE here, never per-page. -->
    <KlufterbachNav
      client:load
      transition:persist="klufterbach-nav"
      sections={sectionData}
      textureUrl={bandTexture.src}
      initialRoute={Astro.url.pathname}
    />
    <slot />
  </body>
</html>

<style is:global>
  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Focus-visible ensures focus rings only show on keyboard navigation */
  :focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* Skip link for a11y */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--sp-5);
    padding: var(--sp-3) var(--sp-4);
    background: var(--wn-green-deep);
    color: var(--wn-paper);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--r-sm);
    z-index: 9999;
    transition: top var(--dur-2) var(--ease-out);
  }
  .skip-link:focus {
    top: var(--sp-5);
  }
</style>
